{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "app/login.js",
    "app/(tabs)/explore.js",
    "app/(tabs)/index.js",
    "app/_layout.js",
    "hooks/use-gptoss.js",
    "hooks/use-auth.js",
    "hooks/lib/auth.js"
  ]
}
